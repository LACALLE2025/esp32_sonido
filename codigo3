#include <BluetoothA2DPSink.h>

BluetoothA2DPSink a2dp_sink;

void setup() {
  // 1. Configuración para usar el DAC INTERNO (GPIO25 y 26)
  i2s_config_t i2s_config = {
      .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_TX | I2S_MODE_DAC_BUILT_IN),
      .sample_rate = 44100,
      .bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT,
      .channel_format = I2S_CHANNEL_FMT_RIGHT_LEFT,
      .communication_format = (i2s_comm_format_t)I2S_COMM_FORMAT_STAND_MSB,
      .intr_alloc_flags = 0,
      .dma_buf_count = 8,
      .dma_buf_len = 64,
      .use_apll = false
  };

  a2dp_sink.set_i2s_config(i2s_config);

  // 2. Iniciar con el nombre del Bluetooth
  // El parámetro 'true' en versiones antiguas activaba el DAC, 
  // pero con set_i2s_config aseguramos la ruta.
  a2dp_sink.start("ESP32_Audio"); 
  
  Serial.begin(115200);
  Serial.println("Bluetooth listo. Conecta tu móvil a 'ESP32_Audio'");
}

void loop() {
  // Nada que hacer aquí
}

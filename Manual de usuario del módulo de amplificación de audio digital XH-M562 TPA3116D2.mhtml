.menu-left { left: 15px; }

.menu-right { right: 15px; }

[dir=3D"rtl"] .menu-left { left: initial; right: 15px; }

[dir=3D"rtl"] .menu-right { left: 15px; right: initial; }

.menu-upper { top: 15px; }

.menu-lower { bottom: 15px; }

.menu-btn-section { padding: 5px 0px; margin: 0px; box-shadow: rgba(0, 0, 0=
, 0.2) 0px 0px 3px 3px; }

